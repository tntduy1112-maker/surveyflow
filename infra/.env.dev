# Dev VPS environment — copy to infra/.env and fill in values

APP_NAME=survey-agent
APP_ENV=development
APP_PORT=8080
VPS_HOST=YOUR_DEV_VPS_IP

DATABASE_URL=postgres://survey_user:CHANGE_ME@postgres:5432/survey_db?sslmode=disable
DB_HOST=postgres
DB_PORT=5432
DB_USER=survey_user
DB_PASSWORD=CHANGE_ME
DB_NAME=survey_db
DB_SSLMODE=disable
DB_POOL_MIN=2
DB_POOL_MAX=10

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

ANTHROPIC_API_KEY=sk-ant-YOUR_REAL_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-6

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@survey.productcon.vn
